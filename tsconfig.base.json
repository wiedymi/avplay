{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true
  }
}
