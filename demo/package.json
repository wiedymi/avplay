{
	"name": "avplay-demo",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --hot src/index.tsx",
    "build": "bash build.sh",
    "serve": "bun src/server.ts",
    "build:serve": "bash build.sh && bun src/server.ts",
		"build-worker": "echo 'Worker is provided by @avplay/core'",
		"start": "NODE_ENV=production bun src/server.ts",
		"clean": "rm -rf dist node_modules"
	},
	"dependencies": {
		"react": "^19",
		"react-dom": "^19",
		"@avplay/react": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@webgpu/types": "^0.1.65"
	}
}
